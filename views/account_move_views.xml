<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_equity_transaction" model="ir.ui.view">
        <field name="name">account.move.form.equity.transaction</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_equity_transaction"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-share-alt"
                    invisible="not equity_transaction_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Equity</span>
                        <span class="o_stat_text">Transaction</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
